// Prisma schema — MySQL. Auth.js (NextAuth) + User extensions.
// Test connection: npx prisma db push (or npm run db:push)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// --- Enums for Financial features ---

enum AccountType {
  BANK
  CREDIT_CARD
  WALLET
  CASH
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  PAYMENT
  INTEREST
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  POSTED
  VOID
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  YEARLY
}

enum ReportCategory {
  BUG
  CALCULATION_ISSUE
  DATA_MISMATCH
  UI_ISSUE
  FEATURE_REQUEST
  OTHER
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum NotificationType {
  EVENT_SLIP_DONE
  EVENT_IMPORT_DONE
  EVENT_CARD_PAYMENT
}

// --- Auth.js required models ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Credentials: hashed password (null for OAuth-only users)
  password      String?   @db.Text
  // Active users: last activity timestamp
  lastActiveAt  DateTime?
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  suspendedAt   DateTime?
  deleteAfter   DateTime?
  deletedAt     DateTime?
  accounts           Account[]
  // JWT session tracking (for list/revoke)
  userSessions       UserSession[]
  activityLogs       ActivityLog[]
  transactions       Transaction[]
  financialAccounts  FinancialAccount[]
  categories         Category[]
  termsAcceptances   UserTermsAcceptance[]
  reports            Report[]
  budgetTemplates        BudgetTemplate[]
  budgetMonths           BudgetMonth[]
  recurringTransactions  RecurringTransaction[]
  notifications          Notification[]
  deletionRequests       UserDeletionRequest[]
}

model UserDeletionRequest {
  id          String    @id @default(cuid())
  userId      String
  reason      String?   @db.Text
  requestedAt DateTime @default(now())
  deleteAfter DateTime
  cancelledAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Tracks active JWT sessions per user (sessionId in JWT cookie).
// Used for "active sessions" list and revoke-one/revoke-all.
// revokedAt: null = active; set when user revokes (soft delete).
model UserSession {
  id           String    @id @default(cuid())
  sessionId    String    @unique
  userId       String
  userAgent    String?   @db.Text
  ipAddress    String?
  lastActiveAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?
  rememberMe   Boolean   @default(false)
  expiresAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires   DateTime

  @@unique([identifier, token])
}

// --- Activity Log (audit trail) ---

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String?
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// --- Financial Accounts (Book Bank) ---

model FinancialAccount {
  id             String   @id @default(cuid())
  name           String
  type           AccountType
  initialBalance Decimal   @db.Decimal(15, 2)
  isActive       Boolean   @default(true)
  isDefault      Boolean   @default(false)
  isHidden       Boolean   @default(false)
  lastCheckedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  transfersTo           Transaction[]          @relation("TransferTo")
  creditCardStatements  CreditCardStatement[]
  recurringTransactions RecurringTransaction[]

  // Credit card specific (nullable for non-CREDIT_CARD accounts)
  creditLimit           Decimal?  @db.Decimal(15, 2)
  statementClosingDay   Int?
  dueDay                Int?
  currentOutstanding    Decimal?  @db.Decimal(15, 2)
  availableCredit       Decimal?  @db.Decimal(15, 2)
  interestRate          Decimal?  @db.Decimal(8, 4)
  interestCalculatedUntil DateTime?
  cardAccountType        String?   // credit | debit | prepaid | other
  cardNetwork            String?   // visa | master | jcb | amex | unionpay | truemoney | other

  // Bank/account identification (optional)
  bankName           String?
  accountNumber      String?  @db.Text  // ciphertext (FULL) or plain last4 (LAST_4_ONLY)
  accountNumberMode  String?  // "FULL" | "LAST_4_ONLY" (BANK, WALLET)

  // Debit card: links to bank account (money comes from this account)
  linkedAccountId    String?
  linkedAccount      FinancialAccount?  @relation("DebitCardLinkedAccount", fields: [linkedAccountId], references: [id], onDelete: SetNull)
  linkedDebitCards   FinancialAccount[] @relation("DebitCardLinkedAccount")

  @@index([userId])
}

// --- Categories (master list) ---

model Category {
  id          String        @id @default(cuid())
  name        String
  nameEn      String?
  isDefault   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions             Transaction[]
  budgetTemplateCategories BudgetTemplateCategory[]
  budgetCategories         BudgetCategory[]
  recurringTransactions    RecurringTransaction[]

  @@unique([userId, name])
  @@index([userId])
}

// --- Income & Expense Transactions ---

model Transaction {
  id                   String            @id @default(cuid())
  userId               String
  type                 TransactionType
  status               TransactionStatus @default(POSTED)
  amount               Decimal           @db.Decimal(15, 2)
  category             String?
  note                 String?           @db.Text
  occurredAt           DateTime
  postedDate           DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  financialAccountId     String?
  transferAccountId      String?
  categoryId             String?
  statementId            String?
  recurringTransactionId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  financialAccount     FinancialAccount?    @relation(fields: [financialAccountId], references: [id], onDelete: Restrict)
  transferAccount      FinancialAccount?    @relation("TransferTo", fields: [transferAccountId], references: [id], onDelete: SetNull)
  categoryRef          Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  statement            CreditCardStatement? @relation(fields: [statementId], references: [id], onDelete: SetNull)
  recurringTransaction RecurringTransaction? @relation(fields: [recurringTransactionId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([financialAccountId])
  @@index([transferAccountId])
  @@index([statementId])
  @@index([recurringTransactionId])
}

// --- Terms & Conditions Acceptance Log ---

model UserTermsAcceptance {
  id           String   @id @default(cuid())
  userId       String
  termsVersion String
  acceptedAt   DateTime @default(now())
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- Credit Card Statement ---

model CreditCardStatement {
  id               String   @id @default(cuid())
  accountId        String
  periodStart      DateTime
  periodEnd        DateTime
  closingDate      DateTime
  dueDate          DateTime
  statementBalance Decimal  @db.Decimal(15, 2)
  minimumPayment   Decimal  @db.Decimal(15, 2)
  paidAmount       Decimal  @default(0) @db.Decimal(15, 2)
  isClosed         Boolean  @default(false)
  isPaid           Boolean  @default(false)
  createdAt        DateTime @default(now())

  account      FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([accountId])
  @@index([accountId, closingDate])
}

// --- Budget Management ---

model BudgetTemplate {
  id          String    @id @default(cuid())
  userId      String
  name        String
  isActive    Boolean   @default(true)
  totalBudget Decimal?  @db.Decimal(15, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryLimits BudgetTemplateCategory[]

  @@index([userId])
}

model BudgetTemplateCategory {
  id           String   @id @default(cuid())
  templateId   String
  categoryId   String?
  limitAmount  Decimal  @db.Decimal(15, 2)
  createdAt    DateTime @default(now())

  template BudgetTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([templateId, categoryId])
  @@index([templateId])
  @@index([categoryId])
}

model BudgetMonth {
  id          String    @id @default(cuid())
  userId      String
  year        Int
  month       Int       // 1-12
  totalBudget Decimal?  @db.Decimal(15, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryBudgets  BudgetCategory[]

  @@unique([userId, year, month])
  @@index([userId, year, month])
}

model BudgetCategory {
  id            String   @id @default(cuid())
  budgetMonthId String
  categoryId    String?
  limitAmount   Decimal  @db.Decimal(15, 2)
  createdAt     DateTime @default(now())

  budgetMonth BudgetMonth @relation(fields: [budgetMonthId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([budgetMonthId, categoryId])
  @@index([budgetMonthId])
  @@index([categoryId])
}

// --- Recurring Transactions (templates for repeating income/expenses) ---

model RecurringTransaction {
  id                 String             @id @default(cuid())
  userId             String
  name               String
  type               TransactionType    // INCOME or EXPENSE only
  amount             Decimal            @db.Decimal(15, 2)
  categoryId         String?
  financialAccountId String?
  frequency          RecurringFrequency
  dayOfMonth         Int?               // 1-31, used for MONTHLY and YEARLY
  monthOfYear        Int?               // 1-12, used for YEARLY only
  startDate          DateTime
  endDate            DateTime?
  isActive           Boolean            @default(true)
  note               String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryRef      Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  financialAccount FinancialAccount? @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  transactions     Transaction[]

  @@index([userId])
  @@index([financialAccountId])
}

// --- Help & Feedback Reports ---

model Report {
  id          String         @id @default(cuid())
  userId      String
  category    ReportCategory
  title       String         @db.VarChar(200)
  description String         @db.Text
  route       String?        @db.VarChar(500)
  appVersion  String?        @db.VarChar(50)
  browserInfo String?        @db.Text
  ipAddress   String?        @db.VarChar(45)
  status      ReportStatus   @default(OPEN)
  imagePaths  String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

// --- In-App Notifications (event-based, persisted per user) ---

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  payload   Json?
  link      String?          @db.VarChar(500)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}
