# Copy to .env and fill in values. Do not commit .env.

APP_ENV=development
APP_NAME=Judtang
APP_VERSION=0.1.0
PATCH_VERSION=0.2a

# Database (Prisma)
DATABASE_URL=mysql://user:password@host:3306/database

# NextAuth (required for auth; use `npx auth secret` or generate a random string)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Encryption for sensitive data (32 bytes base64). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Google OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SMTP_USER=
SMTP_PASSWORD=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=


# Logging
LOG_LEVEL=info
LOG_PATH=logs
