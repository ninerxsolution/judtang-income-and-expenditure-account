# Copy to .env and fill in values. Do not commit .env.

APP_ENV=development
APP_NAME=Judtang
APP_VERSION=0.1.0
PATCH_VERSION=0.2a

# Database (Prisma)
DATABASE_URL=mysql://user:password@host:3306/database

# NextAuth (required for auth; use `npx auth secret` or generate a random string)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3910

# Encryption for sensitive data (32 bytes base64). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Google OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Outbound email: Resend (preferred). If RESEND_API_KEY is unset, SMTP_* is used as fallback.
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPORT_FROM=
EMAIL_REPLY_TO=

# Public site URL for links inside emails (verify, reset, admin report). Used when not in dev (see below).
# On local `next dev` with APP_ENV=development, NEXTAUTH_URL is used instead so links stay on localhost.
APP_BASE_URL=
EMAIL_VERIFY_URL=/verify-email
EMAIL_RESET_PASSWORD_URL=/reset-password

# SMTP fallback / legacy (Nodemailer when RESEND_API_KEY is empty)
SMTP_USER=
SMTP_PASSWORD=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=


# Admin (Help & Feedback backoffice). Report notifications go to ADMIN_REPORT_EMAIL if set, else ADMIN_EMAIL.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_REPORT_EMAIL=

# Public contact form (/contact): notification recipient (e.g. info@yourdomain). If unset, submissions are still stored but no email is sent.
PUBLIC_CONTACT_TO=

# Optional: documented for Cloudflare inbound routing (not read by the app)
SUPPORT_EMAIL=
INFO_EMAIL=

# OCR.space (slip upload; get free key at https://ocr.space/ocrapi/freekey)
OCR_SPACE_API_KEY=

# Logging
LOG_LEVEL=info
LOG_PATH=logs

# Account lifecycle (deactivate grace period in days; default 30)
ACCOUNT_GRACE_PERIOD_DAYS=30
